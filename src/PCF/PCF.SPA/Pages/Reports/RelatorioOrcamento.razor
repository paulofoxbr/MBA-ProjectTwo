@page "/reports/orcamentos"
@attribute [Authorize]

<PageTitle>Relatório de Orçamentos</PageTitle>
<MudContainer>
    <MudPaper>
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudDatePicker Label="Data Inicial" Format="dd/MM/yyyy" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudDatePicker Label="Data Final" Format="dd/MM/yyyy" />
            </MudItem>
            <MudItem xs="12">
                <MudButton Variant="Variant.Filled" Color="Color.Primary">Gerar Relatório</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>
    <MudDataGrid T="OrcamentoResponseViewModel" Items="_orcamentos" Loading="_loading" Hover="true" Bordered="true" SortMode="SortMode.Single" Striped="true" Filterable="true" EditMode="DataGridEditMode.Form" ReadOnly="false">
        <Columns>
            <PropertyColumn Property="x => x.NomeUsuario" Title="Usuário" Editable="false" />
            <PropertyColumn Property="x => x.NomeCategoria" Title="Categoria" Editable="false" Required="false" />
            <PropertyColumn Property="x => x.ValorLimite" Title="Valor Limite" Editable="true" Required="true" />
            <PropertyColumn Property="x => 0.00" Title="Valor Gasto" Editable="false" Required="false" />
        </Columns>

    </MudDataGrid>
</MudContainer>

